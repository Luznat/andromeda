{
  "expo": {
    "name": "Andromeda",
    "slug": "Andromeda",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/logo-andromeda.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "assets/logo-andromeda.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "app.andromeda.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "assets/logo-andromeda.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "assets/logo-andromeda.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
